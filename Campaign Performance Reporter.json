        "jsonBody": "={{ {\"model\": \"llama-3.3-70b-versatile\", \"messages\": [{\"role\": \"user\", \"content\": \"Analyse this campaign data and write a weekly performance report with top campaign, worst campaign, key insights and recommendations.\\n\\nData:\\n\" + $json.campaign_text}]} }}",
