        "jsCode": "const rows = $input.all();\nconst formatted = rows.map(r => \n  `Campaign: ${r.json.Campaign} | Platform: ${r.json.Platform} | CTR: ${r.json.CTR} | Spend: ${r.json.Spend} | CPA: ${r.json.CPA} | Status: ${r.json.Status}`\n).join('\\n');\n\nreturn [{json: {campaign_text: formatted}}];"
